# Database
DATABASE_URL=postgresql://localhost/defi_lp_engine

# RPC Endpoints (replace with Alchemy/Infura for production)
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_ARBITRUM_WS=wss://arb1.arbitrum.io/ws
RPC_BASE=https://mainnet.base.org
RPC_BASE_WS=wss://mainnet.base.org
RPC_OPTIMISM=https://mainnet.optimism.io
RPC_OPTIMISM_WS=wss://mainnet.optimism.io

# Wallet encryption (64 hex chars - generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ports
PORT_DATA=4001
PORT_ML=4002
PORT_EXECUTION=4003
PORT_RISK=4004
PORT_DASHBOARD=4000

# The Graph API key — get free at https://thegraph.com/studio/ → API Keys
# Required for historical data backfill (pool volume history)
GRAPH_API_KEY=

# Paper trading mode (set to false to use real capital)
PAPER_TRADING=true

# Capital allocation
CAPITAL_PER_CHAIN=1000

# Internal API secret — protects critical endpoints between services (kill-switch, tick, close-all)
# Generate with: openssl rand -hex 32
# Must be the same value set in all service environments
INTERNAL_API_SECRET=

# Dashboard URL for CORS — set to your deployed dashboard origin in production
DASHBOARD_URL=http://localhost:4000
